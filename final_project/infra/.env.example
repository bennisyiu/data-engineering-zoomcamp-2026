# Copy to repo ROOT as .env (same folder as README). Never commit .env.
# Warehouse DB: compose includes service "warehouse" — use POSTGRES_HOST=warehouse (default on EC2).
# If insurance_dwh lives on your laptop instead: POSTGRES_HOST=host.docker.internal (and remove warehouse from compose or use a custom override).
# POSTGRES_HOST=warehouse
# POSTGRES_PORT=5432
# POSTGRES_USER=dwh_user
# POSTGRES_PASSWORD=choose_a_strong_password
# POSTGRES_DB=insurance_dwh
# Optional S3 (else pipeline uses repo data/):
# S3_BUCKET_NAME=
# S3_RAW_PREFIX=raw
#
# Optional — Streamlit Text-to-SQL (streamlit_app/); not used by Docker Compose
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=qwen/qwen3.5-flash-02-23
# OPENROUTER_SITE_URL=
# OPENROUTER_APP_NAME=
