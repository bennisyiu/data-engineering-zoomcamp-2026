# Copy to repo ROOT as .env (same folder as README). Never commit .env.
# Warehouse DB credentials (used by compose and by scripts).
# POSTGRES_HOST=localhost is fine when you connect from your laptop to EC2:5432; Airflow/Streamlit
# services in docker-compose.yml override this to hostname `warehouse` inside Docker.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=dwh_user
# POSTGRES_PASSWORD=choose_a_strong_password
# POSTGRES_DB=insurance_dwh
# Optional S3 (else pipeline uses repo data/):
# S3_BUCKET_NAME=
# S3_RAW_PREFIX=raw
#
# Optional — Streamlit Text-to-SQL (streamlit_app/); not used by Docker Compose
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=qwen/qwen3.5-flash-02-23
# exact slug from openrouter.ai/models (not ...-23s)
# OPENROUTER_SITE_URL=
# OPENROUTER_APP_NAME=
